{
  "name": "text_preprocessor",
  "backend": "python",
  "max_batch_size": 1,
  "input": [
    {
      "name": "raw_text",
      "data_type": "TYPE_STRING",
      "dims": [1]
    }
  ],
  "output": [
    {
      "name": "processed_text",
      "data_type": "TYPE_INT32",
      "dims": [512]
    }
  ]
}