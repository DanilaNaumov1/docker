{
  "name": "text_postprocessor",
  "backend": "python",
  "max_batch_size": 1,
  "input": [
    {
      "name": "summary_logits",
      "data_type": "TYPE_FP32",
      "dims": [512]
    }
  ],
  "output": [
    {
      "name": "summary_text",
      "data_type": "TYPE_STRING",
      "dims": [1]
    }
  ]
}